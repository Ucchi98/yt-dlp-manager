# ==========================================
# 共通設定 (固定値および外部設定の読み込み)
# ==========================================
# スクリプトが使用する固定の管理ディレクトリ
APP_DIR="${HOME}/.config/yt-dlp-manager"

# 設定ファイルのパス
CONFIG_FILE="${APP_DIR}/yt-dlp-manager.cfg"

# データベースファイルのパスは APP_DIR 固定とする
DB_PATH="${APP_DIR}/queue.db"

# cookie.txtファイルのパスは APP_DIR 固定とする
COOKIE_FILE="${APP_DIR}/cookie.txt"
ARCHIVE_FILE="${APP_DIR}/archive.txt"
PROGRESS_TEMPLATE="    download:[download] Id: %(info.id)s | %(progress._percent_str)s of %(progress._total_bytes_str)s at %(progress._speed_str)s ETA %(progress._eta_str)s"

# デフォルト値（フォールバック用）
DEFAULT_YTDLP_BIN="/usr/local/bin/yt-dlp"
DEFAULT_DENO_BIN="/usr/local/bin/deno"
DEFAULT_FFMPEG_DIR="/usr/local/bin"
DEFAULT_OUTPUT_TEMPLATE="%(title).200B_%(resolution)s [%(id)s].%(ext)s"

INTERVAL=5

# 設定ファイルが存在すれば読み込む (source)
if [ -f "$CONFIG_FILE" ]; then
    source "$CONFIG_FILE"
fi

# 設定ファイルが無い場合、またはファイル内で値が設定されていない（空）場合、
# デフォルト値を代入。
: "${YTDLP_BIN:=$DEFAULT_YTDLP_BIN}"
: "${DENO_BIN:=$DEFAULT_DENO_BIN}"
: "${FFMPEG_DIR:=$DEFAULT_FFMPEG_DIR}"
: "${OUTPUT_TEMPLATE:=$DEFAULT_OUTPUT_TEMPLATE}"

CURRENT_PROCESSING_ID=""
TARGET_RUN_IDS="" # 処理させるIDのSQL用リスト
VERBOSE_MODE=0    # yt-dlp のデバッグログフラグの初期化
DEBUG_MODE=0

# ==========================================
# 共通関数・ID展開ロジック
# ==========================================
# ==========================================
# ログ出力モジュール
# ==========================================
# ANSIカラーコード
readonly _C_DEBUG="\033[37m"
readonly _C_INFO="\033[39m"
readonly _C_SUCCESS="\033[32m"
readonly _C_WARN="\033[33m"
readonly _C_ERROR="\033[31m"
readonly _C_FATAL="\033[1;31m"
readonly _C_RESET="\033[0m"

log_message() {
    local level=$1
    local message=$2
    local prefix=""
    local color=""
    local stream=1

    case "$level" in
        "DEBUG")   prefix="[Debug]";   color=$_C_DEBUG ;;
        "INFO")    prefix="[Info]";    color=$_C_INFO ;;
        "SUCCESS") prefix="[Success]"; color=$_C_SUCCESS ;;
        "WARN")    prefix="[Warn]";    color=$_C_WARN ;;
        "ERROR")   prefix="[Error]";   color=$_C_ERROR; stream=2 ;;
        "FATAL")   prefix="[Fatal]";   color=$_C_FATAL; stream=2 ;;
        *)         prefix="[Log]";     color=$_C_RESET ;;
    esac

    if [ "$stream" -eq 2 ]; then
        echo -e "${color}${prefix}${_C_RESET}: ${message}" >&2
    else
        echo -e "${color}${prefix}${_C_RESET}: ${message}"
    fi
}

# ショートカット関数
log_newline() { echo "";                    }
log_fatal()   { log_message "FATAL"   "$1"; }
log_error()   { log_message "ERROR"   "$1"; }
log_warn()    { log_message "WARN"    "$1"; }
log_info()    { log_message "INFO"    "$1"; }
log_success() { log_message "SUCCESS" "$1"; }
log_debug() {
    if [ "$DEBUG_MODE" = true ]; then
        log_message "DEBUG" "$1"
    fi
}

