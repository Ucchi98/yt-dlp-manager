bootstrap_application() {
    # 1. Ensure the application management directory exists
    if [ ! -d "$APP_DIR" ]; then
        mkdir -p "$APP_DIR"
    fi
    
    # 2. Generate the default application config file if it does not exist
    if [ ! -f "$APP_CONFIG_FILE" ]; then
        create_default_app_config
    fi

    # 3. Generate the default yt-dlp config file if it does not exist
    if [ ! -f "$YTDLP_CONFIG_FILE" ]; then
        create_default_ytdlp_config
    fi
}

init_database() {
    # bootstrap_application が先に実行されているため、APP_DIR は必ず存在します
    if [ ! -f "$DB_PATH" ]; then
        sqlite3 "$DB_PATH" "CREATE TABLE t_url (id INTEGER PRIMARY KEY AUTOINCREMENT, channel TEXT NOT NULL, url TEXT NOT NULL UNIQUE, base_dir TEXT NOT NULL, done INTEGER DEFAULT 0, created_at TEXT DEFAULT (DATETIME('now', 'localtime')), processed_at TEXT);"
    fi
    sqlite3 "$DB_PATH" "PRAGMA busy_timeout = 5000;" >/dev/null
    sqlite3 "$DB_PATH" "PRAGMA journal_mode = WAL;" >/dev/null
}

parse_and_expand_ids() {
    local id_input="$1"
    local expanded_ids=()
    local max_id=$(sqlite3 "$DB_PATH" "SELECT MAX(id) FROM t_url;")
    [ -z "$max_id" ] && max_id=0

    IFS=',' read -r -a id_parts <<< "$id_input"
    for part in "${id_parts[@]}"; do
        part=$(echo "$part" | xargs)
        [ -z "$part" ] && continue
        
        if [[ "$part" =~ : ]]; then
            local start_id=$(echo "$part" | cut -d':' -f1)
            local end_id=$(echo "$part" | cut -d':' -f2)
            
            # 開始/終了のデフォルト値を設定
            [ -z "$start_id" ] && start_id=1
            [ -z "$end_id" ] && end_id=$max_id
            
            # 【追加ロジック】開始IDが最大値を超えている場合は、そのパーツは無効
            if [ "$start_id" -gt "$max_id" ]; then
                continue
            fi
            # 終了IDを最大値までに制限
            [ "$end_id" -gt "$max_id" ] && end_id=$max_id
            
            # 【追加ロジック】逆順指定の防止
            if [ "$start_id" -gt "$end_id" ]; then
                continue
            fi
            
            for ((id=start_id; id<=end_id; id++)); do
                expanded_ids+=("$id")
            done
        elif [[ "$part" =~ ^[0-9]+$ ]]; then
            # 【追加ロジック】単一ID指定でも最大値を超えていたら含めない
            if [ "$part" -le "$max_id" ]; then
                expanded_ids+=("$part")
            fi
        else
            log_error "Invalid ID format '$part'."
            return 1
        fi
    done

    # 展開結果から重複を除去して返す
    if [ ${#expanded_ids[@]} -gt 0 ]; then
        # スペース区切りをカンマ区切りに置換
        local unique_ids=$(echo "${expanded_ids[@]}" | tr ' ' '\n' | sort -un | paste -sd, -)
        echo "$unique_ids"
    fi
}

# 汎用バリデーション関数
# @param id_list_sql: カンマ区切りのID文字列
# @param allowed_statuses: 許可するステータス値のリスト（例: "0,1,2,3,-1"）
validate_ids() {
    local id_list_sql="$1"
    local allowed_statuses="$2"
    local filtered_ids=()
    
    # IDリストを配列に展開
    IFS=',' read -r -a id_parts <<< "$id_list_sql"
    
    for id in "${id_parts[@]}"; do
        id=$(echo "$id" | xargs)
        [ -z "$id" ] && continue
        
        # IDに紐づくステータス(done)を取得
        local status=$(sqlite3 "$DB_PATH" "SELECT done FROM t_url WHERE id = $id;" | xargs)
        
        # 1. 存在しないIDはスキップ
        if [ -z "$status" ]; then
            continue
        fi
        
        # 2. 許可されたステータスに含まれているか判定
        if [[ ",$allowed_statuses," =~ ",$status," ]]; then
            filtered_ids+=("$id")
        else
            # 必要に応じて「ID x は許可されていないステータスです」というログを出す
            log_debug "ID $id (Status: $status) skipped due to status restriction."
        fi
    done
    
    # 結果をカンマ区切りで返す
    local result=$(IFS=','; echo "${filtered_ids[*]}")
    echo "$result"
}

# ============================================================
# 表示用関数: タスク開始時のステータスボックスを描画する
# ============================================================
print_process_box() {
    local id="$1"
    local channel="$2"
    local url="$3"
    local target_dir="$4"

    # 1. ターミナルの現在の横幅を取得し、右マージン用に1文字分引き算する
    local cols=$(tput cols 2>/dev/null || echo 80)
    cols=$(( cols - 1 ))
    
    # 【安全策】極端に狭いターミナルでの表示崩れを防群のための最低幅
    [ "$cols" -lt 45 ] && cols=45
    
    # 2. 終端のフェードアウトデザイン用パーツ
    local fade_out=" ─ ─ · ·"
    local fade_len=${#fade_out} # 半角8文字分

    # ------------------------------------------------------------
    # 【ズレ対策】上下の罫線の長さを完全に同期させる
    # ------------------------------------------------------------
    # 先にベースとなる共通の線の長さを計算します（下部罫線を基準に決定）
    local base_line_len=$(( cols - 2 - fade_len ))
    [ "$base_line_len" -lt 25 ] && base_line_len=25
    
    # 下部罫線用の線
    local bottom_line=$(printf '─%.0s' $(seq 1 $base_line_len))

    # 上部罫線は、ヘッダーの固定文字数とIDの桁数分（${#id}）をベースの長さから差し引いて計算します。
    # これにより、環境による記号の幅の解釈ズレがあっても、上下の右端の位置が完全に一致します。
    local top_line_len=$(( base_line_len - 21 - ${#id} ))
    [ "$top_line_len" -lt 5 ] && top_line_len=5
    local top_line=$(printf '─%.0s' $(seq 1 $top_line_len))
    # ------------------------------------------------------------

    # ------------------------------------------------------------
    # 【動的インテリジェントURLトリム】
    # ------------------------------------------------------------
    # 左側のインデント「 │  🔗  」（11文字分）を考慮してURL最大表示幅を決定
    local max_url_len=$(( cols - 11 - 1 ))
    
    if [ ${#url} -gt $max_url_len ]; then
        local head_len=$(( max_url_len * 45 / 100 ))
        local tail_len=$(( max_url_len * 45 / 100 ))
        
        [ "$head_len" -lt 12 ] && head_len=12
        [ "$tail_len" -lt 12 ] && tail_len=12
        
        if [ $(( head_len + tail_len + 3 )) -gt $max_url_len ]; then
            tail_len=$(( max_url_len - head_len - 3 ))
        fi

        local url_head="${url:0:$head_len}"
        local url_tail="${url: -${tail_len}}"
        url="${url_head}...${url_tail}"
    fi
    # ------------------------------------------------------------

    # 出力
    # 下部の1本線を絶対基準に相対計算しているため、
    # ターミナルのフォント環境に依存せず、常に右端の点々が綺麗に縦に並びます。
    echo " ╭── Processing [ID: ${id}] ${top_line}${fade_out}"
    echo " │  🎬  ${channel}"
    echo " │  🔗  ${url}"
    echo " │  📁  ${target_dir}"
    echo " ╰${bottom_line}${fade_out}"
}

# ==========================================
# 常駐モード用関数
# ==========================================
reset_interrupted_state() {
    log_debug "Checking for interrupted tasks from previous run..."
    local sql_cmd="UPDATE t_url SET done = -1, processed_at = DATETIME('now', 'localtime') WHERE done = 2"
    if [ -n "$TARGET_RUN_IDS" ]; then
        sql_cmd="$sql_cmd AND id IN ($TARGET_RUN_IDS);"
    else
        sql_cmd="$sql_cmd;"
    fi
    sqlite3 "$DB_PATH" "$sql_cmd"
}

execute_external_process() {
    local id="$1" channel="$2" url="$3" record_base_dir="$4"
    local target_dir="${record_base_dir}/${channel}"

    print_process_box "$id" "$channel" "$url" "$target_dir"

    local ARGS=(
        --config-locations "${YTDLP_CONFIG_FILE}"
        -P "$target_dir"
    )

    if [ "$VERBOSE_MODE" -eq 1 ]; then
        ARGS+=("--verbose")
        log_debug "yt-dlp Debug Log Start (ID: $id)"
    else
        ARGS+=("-q")
    fi

    "${YTDLP_BIN}" "${ARGS[@]}" "$url"
    local status=$?
    if [ "$VERBOSE_MODE" -eq 1 ]; then
        log_debug "yt-dlp Debug Log End (Exit Code: $status)"
    fi
    return $status
}

process_queued_tasks() {
    log_debug "Persistent mode started. Listening to database..."
    
    # 常駐モード用：最後に処理したIDを保持
    local last_processed_id=0

    while true; do
        # 1. 処理対象リストの取得
        local target_ids_sql=""
        if [ -n "$TARGET_RUN_IDS" ]; then
            # 範囲指定がある場合：指定IDのみ、未処理(-1, 0, 3)を全件取得
            target_ids_sql="SELECT id FROM t_url WHERE id IN ($TARGET_RUN_IDS) AND done IN (-1, 0, 3) ORDER BY id ASC;"
        else
            # 常駐モード：前回以降の未処理IDを抽出
            target_ids_sql="SELECT id FROM t_url WHERE id > $last_processed_id AND done IN (-1, 0, 3) ORDER BY id ASC;"
        fi

        local id_list=($(sqlite3 "$DB_PATH" "$target_ids_sql"))

        # 2. リストが空の場合の判定
        if [ ${#id_list[@]} -eq 0 ]; then
            if [ -n "$TARGET_RUN_IDS" ]; then
                log_success "All specified tasks completed. Exiting..."
                exit 0
            fi
            sleep "$INTERVAL"
            continue
        fi

        # 3. ループ処理
        for target_id in "${id_list[@]}"; do
            # アトミックなステータス更新（複数プロセス対策）
            local updated=$(sqlite3 "$DB_PATH" "UPDATE t_url SET done = 2, processed_at = DATETIME('now', 'localtime') WHERE id = $target_id AND done IN (-1, 0, 3) RETURNING id;")
            [ -z "$updated" ] && continue

            CURRENT_PROCESSING_ID="$target_id"
            
            # 各カラムを個別取得
            local channel=$(sqlite3 "$DB_PATH" "SELECT channel FROM t_url WHERE id = $target_id;")
            local url=$(sqlite3 "$DB_PATH" "SELECT url FROM t_url WHERE id = $target_id;")
            local record_base_dir=$(sqlite3 "$DB_PATH" "SELECT base_dir FROM t_url WHERE id = $target_id;")

            mkdir -p "${record_base_dir}/${channel}"

            if execute_external_process "$target_id" "$channel" "$url" "$record_base_dir"; then
                sqlite3 "$DB_PATH" "UPDATE t_url SET done = 1, processed_at = DATETIME('now', 'localtime') WHERE id = $target_id;"
            else
                sqlite3 "$DB_PATH" "UPDATE t_url SET done = -1, processed_at = DATETIME('now', 'localtime') WHERE id = $target_id;"
            fi
            
            # 範囲指定モード以外でのみ更新
            [ -z "$TARGET_RUN_IDS" ] && last_processed_id=$target_id
            CURRENT_PROCESSING_ID=""
        done
        
        # 範囲指定モードの場合は、一通りの処理完了後に終了
        if [ -n "$TARGET_RUN_IDS" ]; then
            log_success "All specified tasks completed. Exiting..."
            exit 0
        fi
    done
}

# ==========================================
# 管理（インサート等）用関数
# ==========================================
list_task() {
    local limit_input="$1" 
    local where_sql="" 
    local limit_sql=""
    local order_sql="ORDER BY id ASC" # 【仕様変更】標準の並び順を昇順（ASC）に統一
    
    if [ -z "$limit_input" ]; then
        # 【仕様変更】引数なしの場合は、全件を昇順（ASC）で表示
        limit_sql=""
        order_sql="ORDER BY id ASC"
        log_debug "All Registered URLs (Oldest First)"
    elif [[ "$limit_input" =~ ^[0-9]+$ ]]; then
        # 件数指定の場合のみ、直近のデータを取得するため降順（DESC）のまま維持
        limit_sql="LIMIT $limit_input"
        order_sql="ORDER BY id DESC"
        log_debug "Recent $limit_input Registered URLs"
    else
        local id_list_sql=$(parse_and_expand_ids "$limit_input")
        
        # 汎用バリデーション: すべてのステータスを許可して存在チェック
        local validated_ids=$(validate_ids "$id_list_sql" "0,1,2,3,-1")
        
        if [ -z "$validated_ids" ]; then 
            log_error "Specified tasks are invalid."
            exit 1
        fi
        
        where_sql="WHERE id IN ($validated_ids)"
        limit_sql=""
        # 【仕様変更】指定ID表示時も昇順（ASC）で出力
        order_sql="ORDER BY id ASC"
        log_debug "Displaying Specified ID: $validated_ids"
    fi

    # 【修正】ヒアドキュメント（<<EOF）を正しく復元し、SQLiteの整形モードを完全に有効化
    local output_data
    output_data=$(sqlite3 "$DB_PATH" <<EOF
.headers on
.mode column
SELECT id AS ID, channel AS Channel, 
    CASE done 
        WHEN 0 THEN '[-] Waiting' 
        WHEN 2 THEN '[*] Processing' 
        WHEN 1 THEN '[o] Done' 
        WHEN 3 THEN '[!] Interrupted' 
        ELSE '[x] Failed' 
    END AS Status, 
    created_at AS Created, 
    COALESCE(processed_at, '-------- --:--:--') AS Processed, 
    base_dir AS 'Base Dir', 
    url AS URL 
FROM t_url 
$where_sql 
$order_sql 
$limit_sql;
EOF
)

    local terminal_lines=$(tput lines 2>/dev/stdout)
    if [ -z "$terminal_lines" ]; then
        terminal_lines=24
    fi
    
    local terminal_cols=$(tput cols 2>/dev/stdout)
    if [ -z "$terminal_cols" ]; then
        terminal_cols=80
    fi
    
    # 出力データの総行数を計算
    local data_lines=$(echo "$output_data" | wc -l | xargs)
    
    # 【修正】色コードを含まない純粋なテキストの段階で、ターミナル横幅を超えているかを判定
    local has_long_line=$(echo "$output_data" | awk -v max="$terminal_cols" 'length($0) > max {found=1; exit} END {print found?1:0}')
    
    # 端末が着色に対応している場合のみ、SQLiteから出力されたプレーンテキストに対してsedで色付けを施す
    if [ -t 1 ] && [ "$(tput colors 2>/dev/null || echo 0)" -ge 8 ]; then
        # BSD sed (macOS/FreeBSD) と GNU sed (Linux) の両方で動作するように物理的なESC文字を変数化
        local esc=$(printf '\033')
        output_data=$(echo "$output_data" | sed \
            -e "s/\[-\] Waiting/${esc}[0m&${esc}[0m/g" \
            -e "s/\[\*\] Processing/${esc}[33m&${esc}[0m/g" \
            -e "s/\[o\] Done/${esc}[32m&${esc}[0m/g" \
            -e "s/\[\!\] Interrupted/${esc}[36m&${esc}[0m/g" \
            -e "s/\[x\] Failed/${esc}[31m&${esc}[0m/g")
    fi

    # 縦の行数が溢れた場合、あるいは横幅を超える行が1行でもある場合に less -S を起動
    # 色コードを維持したままスクロールさせるため、lessに「-R」オプションを追加
    if [ "$data_lines" -gt "$terminal_lines" ] || [ "$has_long_line" -eq 1 ]; then
        echo "$output_data" | less -X -F -S -R
    else
        echo "$output_data"
    fi
    exit 0
}

delete_task_by_ids() {
    local id_input="$1"
    local id_list_sql=$(parse_and_expand_ids "$id_input")
    if [ -z "$id_list_sql" ]; then
        log_error "Specified IDs are invalid. Aborted."
        exit 1
    fi

    # 処理中(2)を除いたIDのみを許可
    local clean_ids=$(validate_ids "$id_list_sql" "0,1,3,-1")
    if [ -z "$clean_ids" ]; then
        log_error "Specified tasks are invalid or currently processing. Aborted."
        exit 1
    fi

    sqlite3 "$DB_PATH" "DELETE FROM t_url WHERE id IN ($clean_ids);"
    log_success "Successfully deleted IDs: $clean_ids"
    exit 0
}

insert_task() {
    local channel="$1" 
    local url_input="$2" 
    local custom_base_dir="$3" 
    local base_dir_to_save=""
    
    if [ -z "$custom_base_dir" ]; then 
        base_dir_to_save="$PWD"
    else 
        base_dir_to_save=$(echo "$custom_base_dir" | sed "s|^~|${HOME}|")
    fi

    local url_array=($url_input) 
    local total_urls=0
    local before_count=0
    local after_count=0

    # 1件以上有効なURLがあるか事前チェック
    local has_valid_url=0
    for url in "${url_array[@]}"; do
        if [ -n "$url" ]; then
            has_valid_url=1
            ((total_urls++))
        fi
    done

    if [ "$has_valid_url" -eq 0 ] || [ "$total_urls" -eq 0 ]; then 
        log_error "No valid URLs provided."
        exit 1
    fi

    # 【確実な件数計算】インサート実行前の総レコード数を取得
    before_count=$(sqlite3 "$DB_PATH" "SELECT COUNT(*) FROM t_url;")

    # SQLiteの対話モードを利用し、トランザクション内で安全に連続インサート
    sqlite3 "$DB_PATH" <<EOF
BEGIN TRANSACTION;
.param init
.param set \$ch '$(echo "$channel" | sed "s/'/''/g")'
.param set \$base '$(echo "$base_dir_to_save" | sed "s/'/''/g")'
$(
for url in "${url_array[@]}"; do
    [ -z "$url" ] && continue
    cat <<INNER_EOF
.param set \$url '$(echo "$url" | sed "s/'/''/g")'
INSERT OR IGNORE INTO t_url (channel, url, base_dir) VALUES (\$ch, \$url, \$base);
INNER_EOF
done
)
COMMIT;
EOF

    # インサート実行後の総レコード数を取得
    after_count=$(sqlite3 "$DB_PATH" "SELECT COUNT(*) FROM t_url;")

    # 差分から「実際に新しく追加された件数」を計算
    local inserted_count=$((after_count - before_count))

    if [ "$inserted_count" -gt 0 ]; then
        log_success "Successfully registered $inserted_count task(s)."
    else
        log_warning "No new tasks were registered (URLs might already exist)."
    fi
}

modify_task_by_ids() {
    local id_input="$1" 
    local mod_path="$2" 
    local mod_channel="$3" 
    local mod_url="$4"
    
    if [ -z "$mod_path" ] && [ -z "$mod_channel" ] && [ -z "$mod_url" ]; then 
        log_error "Nothing to modify."
        exit 1
    fi

    local id_list_sql=$(parse_and_expand_ids "$id_input")
    if [ -z "$id_list_sql" ]; then 
        log_error "Specified tasks are invalid. Aborted."
        exit 1
    fi

    # 処理中(2)を除いたIDのみを許可
    local clean_ids=$(validate_ids "$id_list_sql" "0,1,3,-1")
    if [ -z "$clean_ids" ]; then
        log_error "Specified tasks are invalid or currently processing. Aborted."
        exit 1
    fi

    if [ "$(echo "$clean_ids" | grep -c ',')" -gt 0 ] && [ -n "$mod_url" ]; then 
        log_error "Cannot update URL when multiple IDs are specified. Aborted."
        exit 1
    fi

    # パスのチルダ展開
    if [ -n "$mod_path" ]; then
        mod_path=$(echo "$mod_path" | sed "s|^~|${HOME}|")
    fi

    # 各パラメータが空（指定なし）の場合は NULL としてバインドし、
    # SQL内の COALESCE(? , 原本のカラム名) を使って「指定があった場合のみ更新」を安全に実現します。
    sqlite3 "$DB_PATH" <<EOF
.param init
.param set \$mod_path $([ -n "$mod_path" ] && echo "'$(echo "$mod_path" | sed "s/'/''/g")'" || echo "NULL")
.param set \$mod_ch   $([ -n "$mod_channel" ] && echo "'$(echo "$mod_channel" | sed "s/'/''/g")'" || echo "NULL")
.param set \$mod_url  $([ -n "$mod_url" ] && echo "'$(echo "$mod_url" | sed "s/'/''/g")'" || echo "NULL")

UPDATE t_url 
SET 
    base_dir = COALESCE(\$mod_path, base_dir),
    channel  = COALESCE(\$mod_ch, channel),
    url      = COALESCE(\$mod_url, url)
WHERE id IN ($clean_ids);
EOF

    log_success "Successfully updated record(s) for ID(s): $clean_ids"
    exit 0
}

find_task_by_urls() {
    local url_input="$1" 
    local check_array=($url_input)

    log_debug "URL Duplicate Check"
    for url in "${check_array[@]}"; do
        [ -z "$url" ] && continue
        local id=$(sqlite3 "$DB_PATH" "SELECT id FROM t_url WHERE url = '$(echo "$url" | sed "s/'/''/g")';")
        if [ -n "$id" ]; then
            local channel=$(sqlite3 "$DB_PATH" "SELECT channel FROM t_url WHERE id = $id;")
            local dv=$(sqlite3 "$DB_PATH" "SELECT done FROM t_url WHERE id = $id;")
            local st=""
            case "$dv" in 
                0) st="Waiting" ;; 
                2) st="Processing" ;; 
                1) st="Done" ;; 
                3) st="Interrupted" ;; 
                *) st="Failed" ;; 
            esac
            log_info "[EXISTS] $url -> ID: $id ($channel, $st)"
        else
            log_info "[NEW]    $url"
        fi
    done
    exit 0
}

handle_immediate_shutdown() {
    log_newline
    log_warn "Interrupt signal (Ctrl+C) detected. Aborting process..."
    if [ -n "$CURRENT_PROCESSING_ID" ]; then
        sqlite3 "$DB_PATH" "UPDATE t_url SET done = 3, processed_at = DATETIME('now', 'localtime') WHERE id = $CURRENT_PROCESSING_ID;"
    fi
    exit 130
}
trap handle_immediate_shutdown SIGINT SIGTERM

bootstrap_application
init_database

# ==========================================
# メイン処理 (メインオプション解析)
# ==========================================
start_download_tasks() {
    shift  # "-s" または "--start" を破棄

    case "$#" in
        0) 
            ;;
        1)
            # -s [id_range]
            TARGET_RUN_IDS=$(parse_and_expand_ids "$1")
            if [ -z "$TARGET_RUN_IDS" ]; then
                log_error "Task IDs not found."
                exit 1
            fi
            ;;
        2)
            # -s [id_range] -v のパターン
            if [ "$VERBOSE_MODE" -eq 1 ]; then
                log_error "Invalid usage of -v option."
                exit 1
            fi

            if [[ "$2" =~ ^-(v|-verbose)$ ]]; then
                VERBOSE_MODE=1
            else
                log_error "Invalid usage of -s option."
                exit 1
            fi

            TARGET_RUN_IDS=$(parse_and_expand_ids "$1")
            if [ -z "$TARGET_RUN_IDS" ]; then
                log_error "Task IDs not found."
                exit 1
            fi
            ;;
        *)
            log_error "Too many arguments."
            exit 1
            ;;
    esac

    reset_interrupted_state
    process_queued_tasks
    exit 0
}

case "$1" in
    "-s"|"--start")
        start_download_tasks "$@"
        ;;

    "-v"|"--verbose")
        if [[ ! "$2" =~ ^-(s|-start)$ ]]; then
            log_error "Invalid usage of -v option."
            exit 1
        fi
        VERBOSE_MODE=1
        shift 
        start_download_tasks "$@"
        ;;

    "-m"|"--modify")
        if [ -z "$2" ]; then
            log_error "Missing arguments."
            exit 1
        fi
        
        target_ids="$2"
        shift 2
        
        mod_path=""
        mod_channel=""
        mod_url=""
        
        while [ "$#" -gt 0 ]; do
            case "$1" in
                "-p") mod_path="$2"; shift 2 ;;
                "-c") mod_channel="$2"; shift 2 ;;
                "-u") mod_url="$2"; shift 2 ;;
                *)
                    log_error "Unknown option '$1'."
                    exit 1
                    ;;
            esac
        done
        modify_task_by_ids "$target_ids" "$mod_path" "$mod_channel" "$mod_url"
        ;;
    "-p"|"--path")
        if [ "$#" -lt 4 ]; then
            log_error "Missing arguments."
            exit 1
        fi
        insert_task "$3" "$4" "$2"
        ;;
    "-l"|"--list")
        list_task "$2"
        ;;
    "-d"|"--delete")
        if [ -z "$2" ]; then
            log_error "Missing arguments."
            exit 1
        fi
        delete_task_by_ids "$2"
        ;;
    "-c"|"--check")
        if [ -z "$2" ]; then
            log_error "Missing arguments."
            exit 1
        fi
        find_task_by_urls "$2"
        ;;
    "-h"|"--help")
        print_help
        exit 0
        ;;
    *)
        if [ "$#" -lt 2 ]; then
            print_help >&2
            exit 1
        fi
        insert_task "$1" "$2" "" 
        ;;
esac

